# -*- mode: ruby -*-
# vi: set ft=ruby :
# ============================================================
# Vagrantfile TP2 - Multi-VM (App + DB)
# Architecture : Mac Apple Silicon (ARM64)
# ============================================================

Vagrant.configure("2") do |config|

  # ---------------------------------------------------------------------------
  # VM 1 : srv-db (MySQL)
  # ---------------------------------------------------------------------------
  config.vm.define "srv-db" do |db|
    db.vm.box = "perk/ubuntu-2204-arm64"
    db.vm.hostname = "srv-db"
    
    # Port Forwarding : Host 3306 -> Guest 3306
    db.vm.network "forwarded_port", guest: 3306, host: 3306

    db.vm.provider "qemu" do |qe|
      qe.memory = "1G"
      qe.cpus = 1
      qe.ssh_auto_correct = true
    end

    db.vm.synced_folder ".", "/vagrant", type: "rsync"
    db.vm.provision "shell", path: "db_provision.sh"
  end

  # ---------------------------------------------------------------------------
  # VM 2 : srv-app (Tomcat + Java)
  # ---------------------------------------------------------------------------
  config.vm.define "srv-app" do |app|
    app.vm.box = "perk/ubuntu-2204-arm64"
    app.vm.hostname = "srv-app"

    # Port Forwarding : Host 8080 -> Guest 8080
    app.vm.network "forwarded_port", guest: 8080, host: 8080

    app.vm.provider "qemu" do |qe|
      qe.memory = "2G"
      qe.cpus = 2
      qe.ssh_auto_correct = true
    end

    app.vm.synced_folder ".", "/vagrant", type: "rsync"
    app.vm.synced_folder "./app", "/vagrant_app", type: "rsync"

    app.vm.provision "shell", path: "app_provision.sh"
  end

end
